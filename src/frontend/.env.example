# Google OAuth (Web client) — https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Token tracker API proxy (src/backend/server.js — must match root .env)
VITE_API_BASE=http://127.0.0.1:3001

# App gate: must equal PROXY_AUTH_TOKEN in the repository root .env / .env.example
# (not VITE_PROXY_AUTH_TOKEN — use this exact name so Vite exposes it to the client)
VITE_PROXY_TOKEN=your_proxy_token_here

# Provider API keys (OpenAI/Groq sk-…, Perplexity pplx-…) are entered in the Workspace UI only.
# They are verified on each Run and sent per request — never stored in the database.

# Optional legacy aliases (prefer VITE_API_BASE and VITE_PROXY_TOKEN above):
# VITE_API_BASE_URL=http://127.0.0.1:3001
# VITE_PROXY_AUTH_TOKEN=your_proxy_token_here

# Optional: only needed for redirect-based flows (not popup token sign-in).
# Must match an Authorized redirect URI in Google Cloud Console exactly.
# VITE_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

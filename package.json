{
  "type": "module",
  "scripts": {
    "dev:backend": "node src/backend/server.js",
    "dev:frontend": "npm run dev --prefix src/frontend",
    "build:frontend": "npm run build --prefix src/frontend",
    "db:migrate": "npx prisma migrate deploy",
    "db:migrate:turso": "node scripts/migrate-turso.mjs",
    "db:push": "npx prisma db push",
    "db:verify": "node scripts/verify-db.mjs",
    "db:studio": "npx prisma studio",
    "test": "vitest run",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@prisma/adapter-libsql": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "openai": "^6.38.0",
    "prisma": "^6.19.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
  }
}

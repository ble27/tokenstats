PROXY_AUTH_TOKEN=your_proxy_token_here
FRONTEND_URL=https://your-app.vercel.app,http://localhost:3000

# --- Database (pick one) ---

# Local development (default): SQLite file under prisma/
DATABASE_URL="file:./dev.db"

# Production (Turso): use TURSO_* only — keep DATABASE_URL as file: above
# TURSO_DATABASE_URL="libsql://your-db-name-org.turso.io"
# TURSO_AUTH_TOKEN=your_turso_auth_token
# Apply to Turso: npm run db:migrate:turso

# Optional server-side provider keys (users can paste keys in the UI instead)
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# Copy to .env for: docker compose up --build
# VITE_* values are baked into the frontend image at build time.

PROXY_AUTH_TOKEN=your_long_random_token_here
VITE_API_BASE=http://localhost:3001
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional server-side keys (users can also paste keys in the Workspace UI)
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

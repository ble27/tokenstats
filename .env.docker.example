# Copy to .env for: docker compose up --build

PROXY_AUTH_TOKEN=your_long_random_token_here
VITE_API_BASE=http://localhost:3001
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Local Docker SQLite (default)
DATABASE_URL="file:./dev.db"

# Or Turso (keep DATABASE_URL=file:./dev.db; set TURSO_* for the app)
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token

OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
